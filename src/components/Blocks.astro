---
import BlockContent from './BlockContent.astro';
import { deriveMobileLayout, gridStyle, partitionBlocks, placementStyle } from '../lib/layout.mjs';
import type { Block } from '../lib/blocks';

// Lays out a review's blocks. The rendering of each block lives in
// BlockContent.astro; this file only decides WHERE things go.
//
// Two arrangements, and a review can use both:
//
//   FLOWED  — stacked in order, in the reading column. The default, what
//             the CMS block list produces, and what every review written
//             before the canvas existed uses.
//   PLACED  — positioned on a grid by the canvas editor at /admin/arrange,
//             which is how a photo ends up beside a paragraph or overlapping
//             one.
//
// Placement is grid coordinates, never pixels — see src/lib/blocks.ts. The
// coordinate-to-CSS conversion is in src/lib/layout.mjs, shared with the
// editor, so what a writer drags is exactly what a reader gets.

interface Props {
  blocks: Block[];
}

const { blocks } = Astro.props;

const { flowed, placed } = partitionBlocks(blocks);

// Phone placements, derived from the desktop arrangement unless the writer
// arranged mobile deliberately. Computed once rather than per block.
const mobilePlacements = deriveMobileLayout(placed);
---

<div class="blocks">
  {flowed.map((block) => <BlockContent block={block} />)}

  {
    placed.length > 0 && (
      <div class="block-grid" style={gridStyle()}>
        {placed.map((block) => (
          <div class="block-grid__item" style={placementStyle(block, mobilePlacements.get(block))}>
            <BlockContent block={block} />
          </div>
        ))}
      </div>
    )
  }
</div>

<style>
  .blocks {
    margin-top: 1.5rem;
  }

  /* --- the canvas grid -------------------------------------------------
     Where "put anything anywhere" actually happens.

     The critical rule is `minmax(var(--row-height), auto)`: a row is at
     least one unit tall, but STRETCHES to fit its content. That single
     declaration is what makes a drag-anywhere canvas safe — if a paragraph
     wraps to more lines than the writer allowed for, the row grows and
     pushes everything below it down, instead of the text spilling over the
     block underneath. Nothing measures anything in JavaScript.

     The grid breaks out of the 65ch reading column, because a layout
     someone arranged across a wide canvas is the whole point of arranging
     it. It stops at the viewport, so it can never cause a sideways scroll. */
  .block-grid {
    display: grid;
    grid-template-columns: repeat(var(--grid-columns), 1fr);
    grid-auto-rows: minmax(var(--row-height), auto);
    gap: 0 1rem;
    margin: 2rem 0;
    width: min(100vw - 3rem, 1000px);
    margin-inline: calc(50% - min(50vw - 1.5rem, 500px));
  }

  .block-grid__item {
    grid-area: var(--area-desktop);
    z-index: var(--z);
    /* Positioned items shouldn't carry the flow spacing — the writer's
       coordinates already say where the gaps are. */
    min-width: 0;
  }

  .block-grid__item > :global(.block) {
    margin: 0;
    height: 100%;
  }

  /* Phones get the mobile coordinates: either the writer's, or the derived
     full-width stack. Applied via a media query, which is why the two areas
     are custom properties rather than an inline grid-area — an inline style
     would beat any media query and pin every screen to the desktop layout. */
  @media (max-width: 700px) {
    .block-grid {
      grid-template-columns: repeat(var(--grid-columns-mobile), 1fr);
      width: 100%;
      margin-inline: 0;
    }

    .block-grid__item {
      grid-area: var(--area-mobile);
    }
  }

  .block {
    margin: 1.5rem 0;
  }

  /* --- text ------------------------------------------------------------ */
  /* Sizes map to the shared type scale in global.css rather than literal
     rem values, so changing the scale changes every review at once. */
  .block--text.is-small {
    font-size: var(--type-small);
  }
  .block--text.is-normal {
    font-size: var(--type-normal);
  }
  .block--text.is-large {
    font-size: var(--type-large);
  }
  .block--text.is-display {
    font-size: var(--type-display);
    line-height: 1.2;
  }

  .block--text.is-center {
    text-align: center;
  }

  /* Emphasis names a palette slot, never a literal colour. */
  .block--text.is-accent {
    color: var(--color-accent);
  }
  .block--text.is-muted {
    color: var(--color-muted);
  }

  /* --- image ----------------------------------------------------------- */
  /* The review column is 65ch. `wide` and `full` deliberately break out of
     it using negative margins that bottom out at the viewport, so a
     full-bleed photo never causes a horizontal scrollbar on a phone. */
  .block--image.is-normal {
    max-width: 100%;
  }

  .block--image.is-inset {
    max-width: 60%;
    margin-inline: auto;
  }

  .block--image.is-wide {
    width: min(100vw - 3rem, 900px);
    margin-inline: calc(50% - min(50vw - 1.5rem, 450px));
  }

  .block--image.is-full {
    width: calc(100vw - 3rem);
    margin-inline: calc(50% - (100vw - 3rem) / 2);
  }

  /* Floated images wrap text. They drop to full width on narrow screens —
     a 45% float in a phone column leaves both the image and the text too
     narrow to read. */
  .block--image.is-left,
  .block--image.is-right {
    width: 45%;
    margin-block: 0.4rem;
  }

  .block--image.is-left {
    float: left;
    margin-right: 1.2rem;
  }

  .block--image.is-right {
    float: right;
    margin-left: 1.2rem;
  }

  /* --- gallery --------------------------------------------------------- */
  .block--gallery {
    display: grid;
    gap: 0.75rem;
  }

  .block--gallery.is-2up {
    grid-template-columns: repeat(2, 1fr);
  }

  .block--gallery.is-3up {
    grid-template-columns: repeat(3, 1fr);
  }

  /* --- annotated ------------------------------------------------------- */
  .block__caption {
    margin: 0.4rem 0 0;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  /* --- quote ----------------------------------------------------------- */
  .block--quote {
    margin-inline: 0;
    padding-left: 1rem;
    border-left: 3px solid var(--color-accent);
    font-size: var(--type-large);
    line-height: 1.35;
  }

  .block--quote.is-center {
    text-align: center;
    border-left: none;
    padding-left: 0;
  }

  .block--quote p {
    margin: 0;
  }

  .block--quote cite {
    display: block;
    margin-top: 0.5rem;
    font-size: var(--type-small);
    font-style: normal;
    color: var(--color-muted);
  }

  /* --- dishes ---------------------------------------------------------- */
  .block--dishes ul {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--color-border);
  }

  .dish {
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .dish__head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
  }

  .dish__name {
    font-weight: 600;
  }

  .dish__price {
    color: var(--color-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .dish__note {
    margin: 0.2rem 0 0;
    font-size: var(--type-small);
    color: var(--color-muted);
  }

  /* Floats must not escape the block flow into the next section. */
  .blocks::after {
    content: '';
    display: table;
    clear: both;
  }

  @media (max-width: 640px) {
    .block--image.is-left,
    .block--image.is-right,
    .block--image.is-inset {
      float: none;
      width: 100%;
      max-width: 100%;
      margin-inline: 0;
    }

    /* Three across is unreadable at phone width; stack to two. */
    .block--gallery.is-3up {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
