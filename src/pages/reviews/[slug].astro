---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageCaption from '../../components/ImageCaption.astro';
import Blocks from '../../components/Blocks.astro';
import ReviewSchema from '../../components/ReviewSchema.astro';
import DeskReview from '../../components/DeskReview.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import {
  cuisineSlug,
  getPublishedReviews,
  getRelatedReviews,
  readingTimeMinutes,
  starString,
  type Review,
} from '../../lib/reviews';
import { pageTitle } from '../../lib/site';
import { imageUrl } from '../../lib/images.mjs';

export async function getStaticPaths() {
  // Same helper as everywhere else, so a draft gets a previewable page in
  // dev but no page at all in a production build.
  const reviews = await getPublishedReviews();
  return reviews.map((review) => ({
    params: { slug: review.slug },
    props: { review },
  }));
}

interface Props {
  review: Review;
}

const { review } = Astro.props;
const {
  name,
  rating,
  date,
  updated,
  cover,
  coverAlt,
  cuisine,
  address,
  author,
  draft,
  hotspots,
  blocks,
  desk,
} = review.data;
const { Content } = await review.render();

const stars = starString(rating);
const minutes = readingTimeMinutes(review);

// A draft may not have a blurb yet, and an empty string would emit an empty
// <meta description> rather than falling back. Published reviews always have
// one — the schema enforces it at publish time, not write time.
const metaDescription = review.data.blurb || undefined;

// Structured data needs ABSOLUTE URLs — a search engine has no page context
// to resolve "/reviews/x" against. Falls back to the path when `site:` isn't
// set, which only happens in a misconfigured build.
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
// Social scrapers fetch this directly, so it points at an optimised copy —
// otherwise pasting a link into a chat pulls the full-resolution original.
// 1200px is what the major platforms render a large card at.
const ogImagePath = cover ? imageUrl(cover, 1200) : undefined;
const coverUrl = ogImagePath && Astro.site ? new URL(ogImagePath, Astro.site).href : undefined;

const related = await getRelatedReviews(review, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={pageTitle(name)}
  description={metaDescription}
  image={ogImagePath}
  type="article"
>
  <ReviewSchema slot="head" review={review} url={canonicalUrl} imageUrl={coverUrl} />

  <a href="/">&larr; All reviews</a>

  {
    draft && (
      <p class="draft-banner">
        <strong>Draft.</strong> Not included in production builds.
      </p>
    )
  }

  {
    /* A Sunday Table review IS its layout: the document carries its own
      heading, stars, byline and rule, so the standard chrome below would
      draw all of that a second time above it. Everything the site needs
      about this review still comes from the frontmatter — cards, map,
      search, RSS and the structured data above are untouched. */
  }
  {desk && <DeskReview review={desk} />}

  {
    /* Cover is optional — a review without a photo just opens on its
      heading. Hotspots are opt-in on top of that (frontmatter); no
      `hotspots:` key means a plain captioned cover, which is the right
      default and the reason this page can't ship placeholder pins the way
      it used to. */
  }
  {
    !desk && cover && (
      <ImageCaption
        src={cover}
        alt={coverAlt ?? name}
        mode={hotspots && hotspots.length > 0 ? 'hotspots' : 'visible'}
        hotspots={hotspots ?? []}
        sizes="(max-width: 700px) 100vw, 700px"
        priority
      />
    )
  }

  {!desk && <h1>{name}</h1>}

  {
    !desk && (
      <p class="rating" aria-label={`Rated ${rating} out of 5`}>
        <span aria-hidden="true">{stars}</span>
      </p>
    )
  }

  {
    /* Cuisine links to its index page. Not done on the card, because the
      whole card is already a link and nesting one inside another is invalid
      HTML that browsers resolve unpredictably.

      Kept for desk reviews too: the arrangement shows a cuisine as plain
      text, and this is the only route to that cuisine's page. */
  }
  <p class="review-meta">
    {
      cuisine && (
        <span>
          <a href={`/cuisine/${cuisineSlug(cuisine)}`}>{cuisine}</a> ·{' '}
        </span>
      )
    }
    {address && <span>{address} · </span>}
    <span>{minutes} min read</span>
  </p>

  {
    /* The desk draws its own byline, but only from the text the writer
       typed — "Jul 2026", not a machine-readable date. This keeps the
       <time> element that feed readers and search engines want, and the
       "Updated" line the desk has no field for. */
  }
  <p class="review-byline">
    {!desk && <>By {author} · </>}Published <time datetime={date.toISOString()}>{fmt(date)}</time>
    {
      updated && (
        <>
          {' '}
          · Updated <time datetime={updated.toISOString()}>{fmt(updated)}</time>
        </>
      )
    }
  </p>

  {
    /* Markdown body first, then blocks. A review written by hand has only
      the former; one written in the CMS has only the latter; both render
      the same way and a review may use both. See src/lib/blocks.ts. */
  }
  {
    /* A desk review's body is the arrangement above. The Markdown body and
       `blocks` still render if a file somehow carries both, rather than
       silently dropping writing that exists. */
  }
  <article class="review-body">
    <Content />
    {blocks && blocks.length > 0 && <Blocks blocks={blocks} />}
  </article>

  {
    related.length > 0 && (
      <section class="related">
        <h2>More like this</h2>
        <div class="card-grid">
          {related.map((r) => (
            <ReviewCard review={r} />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .review-meta,
  .review-byline {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: 0.3rem 0;
  }

  .draft-banner {
    background: var(--color-warning-bg);
    border-left: 4px solid var(--color-warning-line);
    padding: 0.6rem 0.9rem;
    border-radius: 4px;
  }

  .review-body {
    max-width: 65ch;
    line-height: 1.7;
    margin-top: 1.5rem;
  }

  .related {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .related h2 {
    margin-top: 0;
  }
</style>
